{
  "compilerOptions": {
    "target": "ES2017",
    "module": "node16",
    "moduleResolution": "node16",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "declaration": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "forceConsistentCasingInFileNames": true,
    "removeComments": true,
  },
  "include": ["src/**/*"]
}