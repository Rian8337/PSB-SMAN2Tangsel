{
  "name": "@psb/shared",
  "private": true,
  "version": "1.0.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./database": {
      "default": "./dist/database/index.js",
      "types": "./dist/database/index.d.ts"
    },
    "./schema": {
      "default": "./dist/database/schema/index.js",
      "types": "./dist/database/schema/index.d.ts"
    },
    "./tests": {
      "default": "./dist/tests/index.js",
      "types": "./dist/tests/index.d.ts"
    },
    "./types": {
      "default": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./validator": {
      "default": "./dist/validator/index.js",
      "types": "./dist/validator/index.d.ts"
    }
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "mysql2": "^3.22.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "typescript": "^5.9.3"
  }
}