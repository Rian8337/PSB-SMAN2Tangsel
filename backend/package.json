    "cors": "^2.8.6",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "express-form-data": "^3.0.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ics": "^3.12.0",
    "jszip": "^3.10.1",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "zod": "^4.4.3"
  }
