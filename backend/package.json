{
  "name": "backend",
  "private": true,
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "dev": "cross-env NODE_ENV=development tsx src/index.ts",
    "push-db:dev": "cross-env NODE_ENV=development drizzle-kit push --force",
    "push-db:test": "cross-env NODE_ENV=test drizzle-kit push --force",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "test": "cross-env NODE_ENV=test vitest",
    "register-admin": "cross-env NODE_ENV=production node dist/cli/register-admin.js",
    "register-admin:dev": "cross-env NODE_ENV=development tsx src/cli/register-admin.ts"
  },
  "keywords": [],
  "author": "Rian8337",
  "license": "MIT",
  "packageManager": "pnpm@10.30.0",
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-form-data": "^2.0.5",
    "@types/node": "^25.9.1",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.8",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "mysql2": "^3.22.4",
    "supertest": "^7.2.2",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@psb/shared": "workspace:*",
